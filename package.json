{
  "name": "tiptap-docs-editor",
  "version": "0.1.16",
  "description": "Notion-style rich text editor built on Tiptap 3 and MUI",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skrishnan771/tiptap-docs-editor.git"
  },
  "peerDependencies": {
    "@emotion/react": ">=11",
    "@emotion/styled": ">=11",
    "@mui/icons-material": ">=6",
    "@mui/material": ">=6",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@tiptap/core": "3.20.5",
    "@tiptap/extension-character-count": "3.20.5",
    "@tiptap/extension-code-block-lowlight": "3.20.5",
    "@tiptap/extension-collaboration": "3.20.5",
    "@tiptap/extension-drag-handle": "3.20.5",
    "@tiptap/extension-drag-handle-react": "3.20.5",
    "@tiptap/extension-emoji": "3.20.5",
    "emojibase": "17.0.0",
    "@tiptap/extension-font-family": "3.20.5",
    "@tiptap/extension-highlight": "3.20.5",
    "@tiptap/extension-image": "3.20.5",
    "@tiptap/extension-link": "3.20.5",
    "@tiptap/extension-node-range": "3.20.5",
    "@tiptap/extension-placeholder": "3.20.5",
    "@tiptap/extension-subscript": "3.20.5",
    "@tiptap/extension-superscript": "3.20.5",
    "@tiptap/extension-table": "3.20.5",
    "@tiptap/extension-table-cell": "3.20.5",
    "@tiptap/extension-table-header": "3.20.5",
    "@tiptap/extension-table-row": "3.20.5",
    "@tiptap/extension-task-item": "3.20.5",
    "@tiptap/extension-task-list": "3.20.5",
    "@tiptap/extension-text-align": "3.20.5",
    "@tiptap/extension-text-style": "3.20.5",
    "@tiptap/extension-typography": "3.20.5",
    "@tiptap/extension-underline": "3.20.5",
    "@tiptap/extension-youtube": "3.20.5",
    "@tiptap/pm": "3.20.5",
    "@tiptap/react": "3.20.5",
    "@tiptap/starter-kit": "3.20.5",
    "@tiptap/suggestion": "3.20.5",
    "@tiptap/y-tiptap": "3.0.2",
    "highlight.js": "11.11.1",
    "lowlight": "3.3.0",
    "y-protocols": "1.0.7",
    "yjs": "13.6.30"
  },
  "devDependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "yaml": "2.8.2"
  }
}
