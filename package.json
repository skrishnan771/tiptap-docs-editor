{
  "name": "tiptap-docs-editor",
  "version": "0.1.5",
  "description": "Notion-style rich text editor built on Tiptap 3 and MUI",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/skrishnan771/tiptap-docs-editor"
  },
  "peerDependencies": {
    "@emotion/react": ">=11",
    "@emotion/styled": ">=11",
    "@mui/icons-material": ">=6",
    "@mui/material": ">=6",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@tiptap/core": "^3.20.1",
    "@tiptap/extension-code-block-lowlight": "^3.20.1",
    "@tiptap/extension-collaboration": "^3.20.1",
    "@tiptap/extension-drag-handle": "^3.20.1",
    "@tiptap/extension-drag-handle-react": "^3.20.1",
    "@tiptap/y-tiptap": "^3.0.2",
    "@tiptap/extension-highlight": "^3.20.1",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-node-range": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-task-item": "^3.20.1",
    "@tiptap/extension-task-list": "^3.20.1",
    "@tiptap/extension-text-align": "^3.20.1",
    "@tiptap/extension-text-style": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@tiptap/suggestion": "^3.20.1",
    "lowlight": "^3.3.0",
    "y-protocols": "^1.0.1",
    "yjs": "^13.5.38"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "typescript-eslint": "^8.57.0"
  }
}